# Create the function
def display_mailing_label(name, address, city, state, zip):
    print(name)
    print(address)
    print(f"{city}, {state} {zip}")

# create the fuction 2
def add_numbers(*args):
    total = sum(args)
    numbers = " + ".join(str(num) for num in args)
    print(f"{numbers} = {total}")

#create function 3
def display_receipt(total_due, amount_paid):

    # calculate change or remaining balance
    change_due = amount_paid - total_due

    # display receipt information
    print(f"Total Due: ${total_due:.2f}")
    print(f"Amount Paid: ${amount_paid:.2f}")

    # check if customer paid enough
    if amount_paid >= total_due:
        print(f"Change Due: ${change_due:.2f}")

    else:
        remaining_balance = total_due - amount_paid
        print(f"Remaining Balance: ${remaining_balance:.2f}")

