import numpy as np

print("=== Numpy Array Creation Function ===\n")

# 1. array() - create from python list
a = np.array([1, 2, 3, 4, 5])
print("np.array[1,2,3,4,5]")
print(a, "\n")
# this is a 1d array

#2. zeros() - array of zeros
b = np.zeros((2, 3))
print("np.zeros((2,3))")
print(b, "\n")

# 3.ones() - array of ones
c = np.ones((2, 2))
print("np.ones((2,2))")

